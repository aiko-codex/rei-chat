# URL of the deployed php-signal endpoint (no trailing slash needed)
# Local testing: php -S 127.0.0.1:8788 from main-app/php-signal → http://127.0.0.1:8788/index.php
VITE_SIGNAL_URL=
# Shared room id (both devices must match; later derived from the passphrase)
VITE_ROOM_ID=rei-room
# Web Push VAPID public key (base64url). Must match the private key in the
# server's secrets.php. Generate a P-256 keypair once; empty = push disabled.
VITE_VAPID_PUBLIC_KEY=
VITE_GIPHY_KEY=